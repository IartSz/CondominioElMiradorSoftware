							},
							"font": "Courier;18;0",
							"parentStyle": false,
							"left": 224,
							"top": 152,
							"width": 200,
							"height": 450,
							"text": "Caso de uso general:\n\n\n+GESTIÓN DE USUARIOS, ROLES Y ACCESO\n\n+GESTIÓN DE RESIDENTES Y UNIDADES\n\n+GESTIÓN FINANCIERA Y COBRANZA\n\n+GESTIÓN DE\nNOTIFICACIONES Y COMUNICACIONES\n\n\n+GESTIÓN DE SOLICITUDES Y ATENCIÓN\n\n\n+ CONSULTAS, VISUALIZACIÓN Y CONTROL\n\n+REPORTES Y\nANÁLISIS\n\n"
						},
						{
							"_type": "UMLTextBoxView",
							"_id": "AAAAAAGeJ2JC4URG9ao=",
							"_parent": {
								"$ref": "AAAAAAGeJ167XkOV4r8="
							},
							"font": "Courier;18;0",
							"parentStyle": false,
							"left": 456,
							"top": 224,
							"width": 184,
							"height": 314,
							"text": "Casos de uso intermedio:\n\n\n\n+Calculo automático de cuotas\n\n\n\n+Gestión de gastos comunes y pagos\n\n\n+Gestión de gastos extraordinarios\n\n+Generación de recibos de pagos\n\n+Gestión de morosidad\n",
							"vertAlign": 5
						},
